    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-istanbul": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
