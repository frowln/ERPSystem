    "@tanstack/react-table": "^8.20.6",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.4.1",
    "react-router": "^7.1.1",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "sockjs-client": "^1.6.1",
