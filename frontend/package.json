{
  "name": "@privod/platform-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "vite build",
    "perf:budget": "node scripts/check-bundle-budgets.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest --dir src",
    "test:run": "vitest run --dir src",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:smoke": "npx playwright test --config=e2e/playwright.config.ts e2e/smoke/",
    "test:e2e:ui": "npx playwright test --config=e2e/playwright.config.ts --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@sentry/react": "^10.38.0",
