# =============================================================================
# PRIVOD NEXT — Frontend Environment Variables
# Copy to .env.local and customize for your environment.
# All variables must be prefixed with VITE_ to be exposed to the browser.
# =============================================================================

# Backend API base URL (proxied in dev via vite.config.ts)
VITE_API_BASE_URL=http://localhost:8080

# Sentry DSN for error tracking (leave empty to disable)
VITE_SENTRY_DSN=

# Application version (used in error reports and UI footer)
VITE_APP_VERSION=1.0.0

# Demo mode — disables write operations and shows demo banner
VITE_DEMO_MODE=false

# Dadata API token for INN/organization lookup
# Register at https://dadata.ru and get a free token (up to 10,000 requests/day)
VITE_DADATA_TOKEN=
