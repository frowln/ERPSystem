# =============================================================================
# PRIVOD NEXT Frontend -- Development Dockerfile
# Vite dev server with Hot Module Replacement (HMR)
# =============================================================================

FROM node:22-alpine

WORKDIR /app

# Install dependencies first for caching
COPY package.json package-lock.json* ./

RUN if [ -f package-lock.json ]; then \
        npm ci; \
    else \
        npm install; \
    fi

# Keep full project snapshot inside image so test/build tooling
# is available even before/without bind mounts.
COPY . .

# Expose Vite dev server port
EXPOSE 3000

# Run Vite dev server with host binding for Docker access
# --host 0.0.0.0 makes the server accessible outside the container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
