# =============================================================================
# PRIVOD2 Server Environment Variables
# Copy to .env and fill in your values:  cp .env.server.example .env
# =============================================================================

# --- Database ---
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- JWT Secret (generate: openssl rand -base64 64) ---
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand

# --- Field Encryption Key (generate: openssl rand -hex 16) ---
FIELD_ENCRYPTION_KEY=CHANGE_ME_32_hex_chars

# --- MinIO (File Storage) ---
MINIO_ROOT_USER=privod_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# --- CORS (comma-separated allowed origins) ---
CORS_ORIGINS=http://192.168.31.2:3002

# --- Email (optional, for password reset emails) ---
# EMAIL_BASE_URL=http://192.168.31.2:3002
