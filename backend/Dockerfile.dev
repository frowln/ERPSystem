# =============================================================================
# PRIVOD NEXT Backend -- Development Dockerfile
# Build JAR at image build time, run with java -jar at runtime
# =============================================================================

FROM gradle:8.12-jdk21 AS builder

WORKDIR /app

# Copy build configuration
COPY build.gradle.kts settings.gradle.kts ./

# Download dependencies (cached layer)
RUN gradle dependencies --no-daemon --stacktrace || true

# Copy source code
COPY src ./src

# Build the JAR (skip tests for dev)
RUN gradle bootJar --no-daemon -x test

# ---------------------------------------------------------------------------
# Runtime stage
# ---------------------------------------------------------------------------
FROM eclipse-temurin:21-jre

WORKDIR /app

# Install curl for health checks
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# Copy the built JAR
COPY --from=builder /app/build/libs/*.jar app.jar

# Expose application port + debug port
EXPOSE 8080 5005

# JVM options for development
ENV JAVA_OPTS="-Xms256m -Xmx768m \
    -XX:+UseG1GC \
    -XX:+UseStringDeduplication \
    -XX:MaxMetaspaceSize=256m \
    -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005"

CMD ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
