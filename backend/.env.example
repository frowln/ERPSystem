# ============================================================================
# ПРИВОД ERP — Environment Variables
# Copy to .env.local and fill in production values
# ============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:15432/privod2
DB_USERNAME=privod
DB_PASSWORD=privod_dev

# Docker profile overrides (application-docker.yml)
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/privod2
# SPRING_DATASOURCE_USERNAME=privod
# SPRING_DATASOURCE_PASSWORD=privod_dev

# Connection pool (prod profile)
# DB_POOL_MAX=50
# DB_POOL_MIN=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=16379

# Docker profile overrides
# SPRING_DATA_REDIS_HOST=redis
# SPRING_DATA_REDIS_PORT=6379

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_256_BIT_SECRET_KEY_HERE
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── MinIO (S3-compatible file storage) ────────────────────────────────────────
STORAGE_ENDPOINT=http://localhost:19000
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio_dev
STORAGE_BUCKET=privod-uploads

# ── Field Encryption (AES-256 key for PII fields) ────────────────────────────
FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── AI Assistant (OpenAI) ─────────────────────────────────────────────────────
AI_API_KEY=

# ── Payment Gateway (YooKassa) ────────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:4000/settings/subscription/result?payment=success
YOOKASSA_WEBHOOK_SECRET=

# ── DaData (company lookup API) ───────────────────────────────────────────────
DADATA_TOKEN=

# ── Sentry (error tracking) ──────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=development

# ── Mail ──────────────────────────────────────────────────────────────────────
# Default: MailHog on localhost:1025 (no auth)
# Production example: Yandex SMTP
MAIL_PORT=1025
# SPRING_MAIL_HOST=smtp.yandex.ru
# SPRING_MAIL_PORT=465
# SPRING_MAIL_USERNAME=noreply@privod.ru
# SPRING_MAIL_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ── Server ────────────────────────────────────────────────────────────────────
# PORT=8080                    # Server port (prod profile)
# API_VERSION=1.0              # API version header

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
REQUEST_LOG_LEVEL=DEBUG

# ── Minstroy Pricing Auto-Import ─────────────────────────────────────────────
PRICING_MINSTROY_AUTO_IMPORT_ENABLED=false
PRICING_MINSTROY_AUTO_IMPORT_CRON=0 0 3 1 * *
