# =============================================================================
# PRIVOD NEXT -- Docker Build Ignore
# =============================================================================

# -------------------------------------------------------------------
# Version control
# -------------------------------------------------------------------
.git
.gitignore

# -------------------------------------------------------------------
# IDE and editor files
# -------------------------------------------------------------------
.idea
.vscode
*.iml
*.ipr
*.iws
.project
.classpath
.settings

# -------------------------------------------------------------------
# Java / Gradle
# -------------------------------------------------------------------
backend/.gradle
backend/build
backend/out
backend/bin
backend/*.jar
backend/gradle/wrapper/gradle-wrapper.jar

# -------------------------------------------------------------------
# Node / Frontend
# -------------------------------------------------------------------
frontend/node_modules
frontend/dist
frontend/.cache
frontend/coverage

# -------------------------------------------------------------------
# Docker
# -------------------------------------------------------------------
**/Dockerfile*
**/docker-compose*
**/.dockerignore

# -------------------------------------------------------------------
# Environment and secrets
# -------------------------------------------------------------------
.env
.env.*
!.env.example

# -------------------------------------------------------------------
# OS files
# -------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# -------------------------------------------------------------------
# Documentation and non-essential files
# -------------------------------------------------------------------
*.md
!frontend/README.md
LICENSE
CHANGES.md
IMPLEMENTATION_STATUS.md
README_DISABLED.txt

# -------------------------------------------------------------------
# Migration and research (not needed in containers)
# -------------------------------------------------------------------
migration/
research/
scripts/

# -------------------------------------------------------------------
# Test artifacts
# -------------------------------------------------------------------
**/test-results
**/test-output
**/*.test.*
**/*.spec.*

# -------------------------------------------------------------------
# Logs
# -------------------------------------------------------------------
*.log
logs/
