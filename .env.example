# =============================================================================
# PRIVOD NEXT -- Environment Variables
# Copy to .env and customize for your environment
# =============================================================================

# -------------------------------------------------------------------
# Database (PostgreSQL 16)
# -------------------------------------------------------------------
POSTGRES_DB=privod2
POSTGRES_USER=privod
POSTGRES_PASSWORD=privod_dev

# -------------------------------------------------------------------
# Redis 7
# -------------------------------------------------------------------
# Only needed for production (dev has no password)
REDIS_PASSWORD=redis_prod_secret

# -------------------------------------------------------------------
# JWT Authentication
# -------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_AT_LEAST_256_BITS
JWT_EXPIRATION_MS=86400000

# -------------------------------------------------------------------
# Spring Boot
# -------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
JAVA_OPTS=-Xms512m -Xmx1g -XX:+UseG1GC

# -------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -------------------------------------------------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev
MINIO_BUCKET=privod-uploads

# -------------------------------------------------------------------
# Mail (MailHog in dev, real SMTP in prod)
# -------------------------------------------------------------------
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# -------------------------------------------------------------------
# Frontend
# -------------------------------------------------------------------
VITE_API_URL=http://localhost:8080

# -------------------------------------------------------------------
# Production only (nginx reverse proxy)
# -------------------------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443
